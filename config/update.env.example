# This file is read only by the root-owned updater.
# ROLE must be "controller" on the Raspberry Pi or "agent" on an Ubuntu host.
ROLE=agent
REPOSITORY_URL=https://github.com/Monkey5283/minecraft-server-manager.git
BRANCH=main
SOURCE_DIR=/opt/minecraft-manager/source
VENV_DIR=/opt/minecraft-manager/venv
