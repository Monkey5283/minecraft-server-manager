# Resolve the newest stable Paper build for this exact Minecraft version when
# an authorized user chooses Apply update. This does not change Minecraft
# versions automatically.
UPDATE_PROVIDER=paper
PAPER_VERSION=26.1.2

# Defaults shown for clarity. Change these to match systemctl show output.
SERVER_DIR=/srv/minecraft/lobby
JAR_NAME=server.jar
SERVICE_NAME=minecraft@lobby.service
