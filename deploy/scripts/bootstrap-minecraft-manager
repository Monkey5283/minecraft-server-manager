#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: sudo bootstrap-minecraft-manager ROLE REPOSITORY_URL [BRANCH]" >&2
  echo "ROLE must be controller or agent" >&2
  exit 2
}

[[ $EUID -eq 0 ]] || {
  echo "run this installer as root" >&2
  exit 1
}

[[ $# -ge 2 && $# -le 3 ]] || usage
role="$1"
repository_url="$2"
branch="${3:-main}"
[[ "$role" == "controller" || "$role" == "agent" ]] || usage
[[ "$repository_url" =~ ^https://[^[:space:]]+$ || "$repository_url" =~ ^ssh://[^[:space:]]+$ || "$repository_url" =~ ^git@[^[:space:]]+:[^[:space:]]+$ ]] || {
  echo "repository URL must use HTTPS or SSH" >&2
  exit 2
}
[[ "$branch" =~ ^[A-Za-z0-9._/-]+$ ]] || {
  echo "invalid branch name" >&2
  exit 2
}

install_root="/opt/minecraft-manager"
source_dir="${install_root}/source"
venv_dir="${install_root}/venv"
config_dir="/etc/minecraft-manager"

export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install --yes git python3 python3-venv

if ! getent passwd mcmanager >/dev/null; then
  useradd --system --create-home --shell /usr/sbin/nologin mcmanager
fi
install -d --owner=mcmanager --group=mcmanager --mode=0755 "$install_root"
install -d --owner=root --group=mcmanager --mode=0750 "$config_dir"

if [[ -d "${source_dir}/.git" ]]; then
  sudo -u mcmanager git -C "$source_dir" fetch --prune origin "$branch"
  sudo -u mcmanager git -C "$source_dir" checkout --force -B "$branch" "origin/${branch}"
else
  if [[ -e "$source_dir" ]]; then
    echo "${source_dir} exists but is not a Git checkout; refusing to replace it" >&2
    exit 1
  fi
  sudo -u mcmanager git clone --branch "$branch" --single-branch \
    "$repository_url" "$source_dir"
fi

if [[ ! -x "${venv_dir}/bin/python" ]]; then
  sudo -u mcmanager python3 -m venv "$venv_dir"
fi
sudo -u mcmanager "${venv_dir}/bin/python" -m pip install --upgrade pip
sudo -u mcmanager "${venv_dir}/bin/python" -m pip install --upgrade "$source_dir"

{
  printf 'ROLE=%q\n' "$role"
  printf 'REPOSITORY_URL=%q\n' "$repository_url"
  printf 'BRANCH=%q\n' "$branch"
  printf 'SOURCE_DIR=%q\n' "$source_dir"
  printf 'VENV_DIR=%q\n' "$venv_dir"
} >"${config_dir}/update.env"
chown root:root "${config_dir}/update.env"
chmod 0600 "${config_dir}/update.env"

install -m 0755 "${source_dir}/deploy/scripts/update-minecraft-manager" \
  /usr/local/sbin/update-minecraft-manager

if [[ "$role" == "controller" ]]; then
  if [[ ! -e "${config_dir}/controller.toml" ]]; then
    install -o root -g mcmanager -m 0640 \
      "${source_dir}/config/controller.example.toml" \
      "${config_dir}/controller.toml"
  fi
  if [[ ! -e "${config_dir}/controller.env" ]]; then
    install -o root -g mcmanager -m 0640 \
      "${source_dir}/config/controller.env.example" \
      "${config_dir}/controller.env"
  fi
  install -m 0644 "${source_dir}/deploy/systemd/mc-manager-controller.service" \
    /etc/systemd/system/mc-manager-controller.service
  install -m 0755 "${source_dir}/deploy/scripts/update-minecraft-manager-fleet" \
    /usr/local/bin/update-minecraft-manager-fleet
  install -m 0755 "${source_dir}/deploy/scripts/setup-minecraft-manager-tailscale" \
    /usr/local/sbin/setup-minecraft-manager-tailscale
  if [[ ! -e "${config_dir}/fleet" ]]; then
    install -o root -g mcmanager -m 0640 \
      "${source_dir}/config/fleet.example" "${config_dir}/fleet"
  fi
  service_name="mc-manager-controller.service"
else
  apt-get install --yes default-jre-headless
  if ! getent passwd minecraft >/dev/null; then
    useradd --system --create-home --home-dir /srv/minecraft --shell /usr/sbin/nologin minecraft
  fi
  usermod --append --groups minecraft mcmanager
  # This path must exist before systemd builds the agent's ProtectSystem=strict
  # mount namespace. The optional ReadWritePaths entry cannot make a directory
  # writable later if it was absent when the service started.
  install -d --owner=root --group=minecraft --mode=2770 /srv/minecraft-backups
  if [[ ! -e "${config_dir}/agent.toml" ]]; then
    install -o root -g mcmanager -m 0640 \
      "${source_dir}/config/agent.onboarding.example.toml" \
      "${config_dir}/agent.toml"
    agent_name="$(hostname --short)"
    if [[ "$agent_name" =~ ^[A-Za-z0-9._-]+$ ]]; then
      sed -i \
        -e "s/^name = \"minecraft-host\"/name = \"${agent_name}\"/" \
        -e "s/^instance_id = \"minecraft-host\"/instance_id = \"${agent_name}\"/" \
        "${config_dir}/agent.toml"
    fi
  fi
  if [[ ! -e "${config_dir}/agent.env" ]]; then
    agent_token="$(python3 -c 'import secrets; print(secrets.token_hex(32))')"
    printf 'MC_AGENT_TOKEN=%s\n' "$agent_token" >"${config_dir}/agent.env"
    chown root:mcmanager "${config_dir}/agent.env"
    chmod 0640 "${config_dir}/agent.env"
  fi
  if ! grep -q '^\[discovery\]$' "${config_dir}/agent.toml"; then
    agent_name="$(hostname --short)"
    [[ "$agent_name" =~ ^[A-Za-z0-9._-]+$ ]] || agent_name="minecraft-host"
    printf '\n[discovery]\nenabled = true\nport = 8765\ninstance_id = "%s"\n' \
      "$agent_name" >>"${config_dir}/agent.toml"
  fi
  if ! grep -q '^\[provisioning\]$' "${config_dir}/agent.toml"; then
    printf '\n[provisioning]\nenabled = true\nmanaged_servers_file = "/srv/minecraft/.manager/managed-servers.json"\n' \
      >>"${config_dir}/agent.toml"
  fi
  install -m 0644 "${source_dir}/deploy/systemd/mc-manager-agent.service" \
    /etc/systemd/system/mc-manager-agent.service
  install -m 0755 "${source_dir}/deploy/scripts/update-minecraft-jar" \
    /usr/local/sbin/update-minecraft-jar
  install -m 0755 "${source_dir}/deploy/scripts/update-minecraft-plugins" \
    /usr/local/sbin/update-minecraft-plugins
  install -m 0755 "${source_dir}/deploy/scripts/backup-minecraft" \
    /usr/local/sbin/backup-minecraft
  install -m 0755 "${source_dir}/deploy/scripts/start-minecraft-server" \
    /usr/local/sbin/start-minecraft-server
  install -m 0644 "${source_dir}/deploy/systemd/minecraft@.service" \
    /etc/systemd/system/minecraft@.service
  install -o root -g root -m 0440 \
    "${source_dir}/deploy/sudoers/minecraft-manager-provisioning" \
    /etc/sudoers.d/minecraft-manager-provisioning
  visudo -cf /etc/sudoers.d/minecraft-manager-provisioning
  service_name="mc-manager-agent.service"
fi

systemctl daemon-reload
systemctl enable "$service_name"

echo
echo "Installed ${role} files. Existing configuration was not overwritten."
echo "Edit the files in ${config_dir}, then start with:"
echo "  sudo systemctl restart ${service_name}"
if [[ "$role" == "agent" ]]; then
  echo "Pair this agent from the controller dashboard with the token shown by:"
  echo "  sudo sed -n 's/^MC_AGENT_TOKEN=//p' ${config_dir}/agent.env"
fi
